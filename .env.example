# AskGloucester ingestion — endpoints only, no secrets.
# Auth is via DefaultAzureCredential (az login / managed identity).
# Copy to .env and fill in the values from your deployment outputs.

# Blob storage account name (Bicep output: storageAccountName)
AZURE_STORAGE_ACCOUNT_NAME=stakgloucesterdev
RAW_DOCUMENTS_CONTAINER=raw-documents

# Document Intelligence endpoint (Bicep output: documentIntelligenceEndpoint)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://docintel-askgloucester-dev.cognitiveservices.azure.com/

# Azure AI Search endpoint (Bicep output: searchEndpoint)
AZURE_SEARCH_ENDPOINT=https://srch-askgloucester-dev.search.windows.net
AZURE_SEARCH_INDEX_NAME=gloucester-documents

# Azure OpenAI endpoint (Bicep output: openAiEndpoint) and the name of the
# text-embedding-3-small deployment (Bicep output: openAiEmbeddingDeployment).
# The subdomain has a per-deployment suffix generated by Bicep's uniqueString();
# copy the real value from the Bicep openAiEndpoint output (don't use XXXXX).
AZURE_OPENAI_ENDPOINT=https://aoai-askgloucester-dev-XXXXX.openai.azure.com/
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# Source site to scrape
AGENDA_CENTER_URL=https://www.gloucester-ma.gov/AgendaCenter
